# Web3Forms access key (https://web3forms.com)
# No longer used — contact form now uses LeadConnector inline embed.
# Kept here for history; safe to remove once confirmed unused.
VITE_WEB3FORMS_ACCESS_KEY=

# Retell AI — server-side only. Set this in Vercel as a Project Environment
# Variable (Production + Preview). NEVER commit the real key and NEVER prefix
# it with VITE_ — the VITE_ prefix would expose it to the browser bundle.
# The Edge Function at api/retell-web-call.ts reads this to mint short-lived
# web-call access tokens for the public agent_id hardcoded in that function.
RETELL_API_KEY=
