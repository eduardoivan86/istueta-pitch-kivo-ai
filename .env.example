# Web3Forms access key (https://web3forms.com)
# No longer used — contact form now uses LeadConnector inline embed.
# Kept here for history; safe to remove once confirmed unused.
VITE_WEB3FORMS_ACCESS_KEY=

# Vapi Web SDK - Public API Key (from Vapi dashboard → Settings → API Keys)
# Without this key the voice orb renders in static-demo mode (no live call).
# Set in Vercel env vars (Production + Preview + Development) then redeploy.
VITE_VAPI_PUBLIC_KEY=your_public_key_here
